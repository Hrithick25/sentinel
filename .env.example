# ═══════════════════════════════════════════════════════════════════════════════
#  SENTINEL v3.0 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
#  Two deployment modes:
#    1. LIGHTWEIGHT (Supabase)  → No Docker needed. Set DATABASE_BACKEND=supabase
#    2. SELF-HOSTED (Docker)    → docker compose up. Set DATABASE_BACKEND=postgres
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-in-production

# ── Database Backend ──────────────────────────────────────────────────────────
# Options: "postgres" (self-hosted Docker) or "supabase" (cloud, no Docker)
DATABASE_BACKEND=supabase

# ── Supabase (when DATABASE_BACKEND=supabase) ─────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── PostgreSQL (when DATABASE_BACKEND=postgres) ──────────────────────────────
# Only needed if using Docker self-hosted mode
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel_db

# ── Redis (optional — empty = in-memory fallback) ────────────────────────────
# For production self-hosted: redis://localhost:6379
# Leave empty for lightweight mode (uses in-memory cache)
REDIS_URL=

# ── Kafka (optional — empty = disabled) ──────────────────────────────────────
# For production self-hosted: localhost:29092
# Leave empty to disable (audit writes go directly to DB)
KAFKA_BOOTSTRAP_SERVERS=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ── Stripe (optional) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Gateway URL (used by SDK) ────────────────────────────────────────────────
GATEWAY_URL=http://localhost:8000
