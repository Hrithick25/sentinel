# ═══════════════════════════════════════════════════════════════════════════════
#  SENTINEL — .gitignore
#  Open-source release: excludes personal configs, generated files, secrets
# ═══════════════════════════════════════════════════════════════════════════════

# ── Secrets / Environment ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.nox/
.tox/

# ── Node.js / React (Dashboard) ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dashboard/
.pnpm-debug.log*

# ── OS Generated Files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── IDEs / Editors ────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.settings/

# ── Sentinel Data / Logs ─────────────────────────────────────────────────────
data/faiss_index/
data/cache/
logs/
*.log

# ── Personal / Internal Files (not for public repo) ──────────────────────────
# Architecture diagrams and internal review docs
sentinel_*.html
sentinel_*.svg
sentinel_review.html
sentinel_project_card.html
sentinel_full_website_experience.html

# VS Code extension build artifacts
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/*.vsix

# ── Agent skill files (internal tooling) ─────────────────────────────────────
.agent/

# ── Dev container config ─────────────────────────────────────────────────────
.devcontainer/
