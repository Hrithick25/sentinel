*.egg
.pytest_cache/
.coverage
htmlcov/
.nox/
.tox/

# ── Node.js / React (Dashboard) ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dashboard/dist/
dashboard/build/
.pnpm-debug.log*

# ── OS Generated Files ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

